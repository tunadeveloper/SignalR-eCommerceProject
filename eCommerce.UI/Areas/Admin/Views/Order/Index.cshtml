@using eCommerce.DTO.DTOs.OrderDTOs
@using eCommerce.DTO.DTOs.OrderDetailDTOs
@using eCommerce.DTO.DTOs.PaymentTransactionDTOs
@model List<ResultOrderDTO>
@{
    ViewData["Title"] = "Siparişler";
    Layout = "~/Areas/Admin/Views/AdminLayout/_Layout.cshtml";
    int count = 0;
    int dCount = 0;
    int mCount = 0;
    var allDetails = ViewBag.OrderDetails as List<ResultOrderDetailDTO>;
    var allPayments = ViewBag.Payments as List<ResultPaymentTransactionDTO>;
}

<div class="col-xl-12">
    <div class="card card-lg shadow-sm">
        <div class="card-header bg-transparent border-bottom py-4">
            <div class="d-flex align-items-center justify-content-between w-100">
                <div>
                    <h5 class="mb-1">Sipariş Listesi</h5>
                    <div class="text-secondary small">Toplam: @Model?.Count</div>
                </div>
                <a href="/Admin/Order/InsertOrder/" class="btn btn-success btn-sm">Yeni Sipariş</a>
            </div>
        </div>
        <div class="px-4 pt-4">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
                    @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
                    @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
        </div>
        <div class="table-responsive">
            <table class="table align-middle text-nowrap mb-0 table-centered table-hover table-striped">
                <thead class="table-light">
                    <tr>
                        <th class="text-uppercase small text-secondary">#</th>
                        <th class="text-uppercase small text-secondary">Müşteri</th>
                        <th class="text-uppercase small text-secondary">Toplam</th>
                        <th class="text-uppercase small text-secondary">Durum</th>
                        <th class="text-uppercase small text-secondary">Kargo</th>
                        <th class="text-uppercase small text-secondary text-end">İşlem</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        count++;
                        <tr>
                            <td class="fw-semibold">@count</td>
                            <td>
                                <div class="d-flex flex-column">
                                    <span class="fw-semibold text-truncate">@item.CustomerName</span>
                                    <span class="text-secondary small">#@item.Id</span>
                                </div>
                            </td>
                            <td>@item.TotalPrice ₺</td>
                            <td>
                                <span class="badge bg-primary-subtle text-primary-emphasis">@item.OrderStatus</span>
                            </td>
                            <td>@item.ShippingCompanyName</td>
                            <td class="text-end">
                                <div class="d-inline-flex gap-2">
                                    <button type="button" class="btn btn-secondary btn-sm"
                                            data-bs-toggle="modal" data-bs-target="#detailModal-@item.Id">
                                        Detaylar
                                    </button>
                                    <a href="/Admin/Order/UpdateOrder/@item.Id" class="btn btn-info btn-sm">Düzenle</a>
                                    <a href="/Admin/Order/DeleteOrder/@item.Id" class="btn btn-danger btn-sm">Sil</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@foreach (var item in Model)
{
    mCount++;
    var details = allDetails.Where(d => d.OrderId.ToString() == item.Id).ToList();
    var payment = allPayments.FirstOrDefault(p => p.OrderId.ToString() == item.Id);

    <div class="modal fade" id="detailModal-@item.Id" tabindex="-1"
         aria-labelledby="detailModalLabel-@item.Id" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <div>
                        <h5 class="modal-title mb-0" id="detailModalLabel-@item.Id">
                            Sipariş Detayı &mdash; <span class="text-secondary">#@item.Id</span>
                        </h5>
                        <div class="small text-secondary">@item.CustomerName</div>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body p-4">
                    <h6 class="fw-semibold text-uppercase small text-secondary mb-3">Sipariş Bilgileri</h6>
                    <div class="row g-3 mb-4">
                        <div class="col-6 col-md-3">
                            <div class="p-3 rounded bg-light h-100">
                                <div class="text-secondary small mb-1">Müşteri</div>
                                <div class="fw-semibold">@item.CustomerName</div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="p-3 rounded bg-light h-100">
                                <div class="text-secondary small mb-1">Toplam Tutar</div>
                                <div class="fw-semibold">@item.TotalPrice ₺</div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="p-3 rounded bg-light h-100">
                                <div class="text-secondary small mb-1">Durum</div>
                                <div>
                                    <span class="badge bg-primary-subtle text-primary-emphasis">@item.OrderStatus</span>
                                </div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="p-3 rounded bg-light h-100">
                                <div class="text-secondary small mb-1">Kargo Firması</div>
                                <div class="fw-semibold">@item.ShippingCompanyName</div>
                            </div>
                        </div>
                    </div>

                    <h6 class="fw-semibold text-uppercase small text-secondary mb-3">Sipariş Ürünleri</h6>
                        <div class="table-responsive mb-4">
                            <table class="table table-sm table-bordered align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th class="text-uppercase small text-secondary">#</th>
                                        <th class="text-uppercase small text-secondary">Ürün</th>
                                        <th class="text-uppercase small text-secondary text-center">Adet</th>
                                        <th class="text-uppercase small text-secondary text-end">Birim Fiyat</th>
                                        <th class="text-uppercase small text-secondary text-end">Toplam</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var d in details)
                                    {
                                        dCount++;
                                        <tr>
                                            <td class="text-secondary small">@dCount</td>
                                            <td class="fw-semibold">@d.ProductName</td>
                                            <td class="text-center">@d.Quantity</td>
                                            <td class="text-end">@d.UnitPrice ₺</td>
                                            <td class="text-end fw-semibold">@(d.Quantity * d.UnitPrice) ₺</td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot class="table-light">
                                    <tr>
                                        <td colspan="4" class="text-end fw-bold">Ara Toplam</td>
                                        <td class="text-end fw-bold">@details.Sum(d => d.Quantity * d.UnitPrice) ₺</td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>

                    <h6 class="fw-semibold text-uppercase small text-secondary mb-3">Ödeme Bilgileri</h6>
                        <div class="row g-3">
                            <div class="col-6 col-md-4">
                                <div class="p-3 rounded bg-light h-100">
                                    <div class="text-secondary small mb-1">Ödeme Yöntemi</div>
                                    <div class="fw-semibold">@payment.PaymentMethod</div>
                                </div>
                            </div>
                            <div class="col-6 col-md-4">
                                <div class="p-3 rounded bg-light h-100">
                                    <div class="text-secondary small mb-1">Müşteri</div>
                                    <div class="fw-semibold">@payment.CustomerName</div>
                                </div>
                            </div>
                            <div class="col-6 col-md-4">
                                <div class="p-3 rounded bg-light h-100">
                                    <div class="text-secondary small mb-1">Ödeme Durumu</div>
                                    <div>
                                        @if (payment.IsSuccessful)
                                        {
                                            <span class="badge text-success-emphasis bg-success-subtle">✓ Başarılı</span>
                                        }
                                        else
                                        {
                                            <span class="badge text-danger-emphasis bg-danger-subtle">✗ Başarısız</span>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }

                </div>

                <div class="modal-footer">
                    <a href="/Admin/Order/UpdateOrder/@item.Id" class="btn btn-info btn-sm">Siparişi Düzenle</a>
                    <button type="button" class="btn btn-light btn-sm" data-bs-dismiss="modal">Kapat</button>
                </div>

            </div>
        </div>
    </div>
}
