@using eCommerce.DTO.DTOs.OrderDTOs
@model CreateOrderDTO
@{
    ViewData["Title"] = "Sipariş Ekle";
    Layout = "~/Areas/Admin/Views/AdminLayout/_Layout.cshtml";
}

<div class="row justify-content-center align-items-center py-4" style="min-height: calc(100vh - 140px);">
    <div class="col-12 col-md-10 col-lg-8 col-xl-7 col-xxl-6">
        <div class="card card-lg shadow-lg border-0">
            <div class="card-header bg-transparent border-bottom py-4">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <h5 class="mb-1">Sipariş Ekle</h5>
                        <div class="text-secondary">Sipariş bilgilerini gir</div>
                    </div>
                    <span class="badge bg-primary-subtle text-primary-emphasis">Yeni</span>
                </div>
            </div>
            <div class="card-body p-4 p-lg-5">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        @TempData["Success"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        @TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
                <form asp-area="Admin" asp-controller="Order" asp-action="InsertOrder" method="post" class="d-flex flex-column gap-3">
                    <div>
                        <label name="CustomerName" class="form-label"></label>
                        <input name="CustomerName" class="form-control form-control-lg" placeholder="Müşteri adı" required />
                        <span asp-validation-for="CustomerName" class="text-danger"></span>
                    </div>

                    <div>
                        <label name="TotalPrice" class="form-label"></label>
                        <input name="TotalPrice" class="form-control form-control-lg" placeholder="Toplam tutar" required />
                        <span asp-validation-for="TotalPrice" class="text-danger"></span>
                    </div>

                    <div>
                        <label name="OrderStatus" class="form-label"></label>
                        <input name="OrderStatus" class="form-control form-control-lg" placeholder="Sipariş durumu" required />
                        <span asp-validation-for="OrderStatus" class="text-danger"></span>
                    </div>

                    <div>
                        <label class="form-label">Kargo Firması</label>
                        <select name="ShippingCompanyId" class="form-select form-select-lg" required>
                            <option value="">Firma seçiniz</option>
                            @foreach (var item in ViewBag.ShippingCompanies)
                            {
                                <option value="@item.Id">@item.CompanyName</option>
                            }
                        </select>
                        <span asp-validation-for="ShippingCompanyId" class="text-danger"></span>
                    </div>

                    <div class="d-flex gap-2 pt-2">
                        <button type="submit" class="btn btn-success">Kaydet</button>
                        <a href="/Admin/Order/Index" class="btn btn-light">İptal</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

