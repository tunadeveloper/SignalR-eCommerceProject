@using eCommerce.DTO.DTOs.PaymentTransactionDTOs
@using eCommerce.DTO.DTOs.OrderDTOs
@model CreatePaymentTransactionDTO
@{
    ViewData["Title"] = "Ödeme Ekle";
    Layout = "~/Areas/Admin/Views/AdminLayout/_Layout.cshtml";
}

<div class="row justify-content-center align-items-center py-4" style="min-height: calc(100vh - 140px);">
    <div class="col-12 col-md-10 col-lg-8 col-xl-7 col-xxl-6">
        <div class="card card-lg shadow-lg border-0">
            <div class="card-header bg-transparent border-bottom py-4">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <h5 class="mb-1">Ödeme Ekle</h5>
                        <div class="text-secondary">Yeni ödeme bilgilerini gir</div>
                    </div>
                    <span class="badge bg-primary-subtle text-primary-emphasis">Yeni</span>
                </div>
            </div>
            <div class="card-body p-4 p-lg-5">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        @TempData["Success"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        @TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
                <form asp-area="Admin" asp-controller="PaymentTransaction" asp-action="InsertPaymentTransaction" method="post" class="d-flex flex-column gap-3">
                    <div>
                        <label class="form-label">Sipariş</label>
                        <select name="OrderId" class="form-select form-select-lg" required>
                            <option value="">Sipariş seçiniz</option>
                            @foreach (var item in ViewBag.Orders)
                            {
                                <option value="@item.Id">@item.CustomerName (#@item.Id)</option>
                            }
                        </select>
                        <span asp-validation-for="OrderId" class="text-danger"></span>
                    </div>

                    <div>
                        <label name="PaymentMethod" class="form-label"></label>
                        <input name="PaymentMethod" class="form-control form-control-lg" placeholder="Ödeme yöntemi" required />
                        <span asp-validation-for="PaymentMethod" class="text-danger"></span>
                    </div>

                    <div>
                        <label class="form-label">Başarılı mı?</label>
                        <select name="IsSuccessful" class="form-select form-select-lg" required>
                            <option value="">Seçiniz</option>
                            <option value="true">Evet</option>
                            <option value="false">Hayır</option>
                        </select>
                        <span asp-validation-for="IsSuccessful" class="text-danger"></span>
                    </div>

                    <div class="d-flex gap-2 pt-2">
                        <button type="submit" class="btn btn-success">Kaydet</button>
                        <a href="/Admin/PaymentTransaction/Index" class="btn btn-light">İptal</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

