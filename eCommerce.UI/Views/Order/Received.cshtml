@{
    ViewData["Title"] = "Sipariş Alındı";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<main>
    <section class="page-hero">
        <div class="container">
            <h1>Sipariş Alındı</h1>
            <p>Siparişiniz başarıyla oluşturuldu. Hazırlık süreci başlatıldı.</p>
        </div>
    </section>

    <section class="container mb-10">
        <div class="modern-card p-4 p-lg-5 text-center max-w-3xl mx-auto">
            <span class="success-icon-wrap mb-3">
                <i class="ti ti-check"></i>
            </span>
            <h2 class="section-title mb-2">Teşekkürler, siparişiniz alındı.</h2>
            <p class="text-gray-600 mb-4">
                Sipariş numaranız <strong>#FC-2026-1048</strong>. Kısa süre içinde e-posta ile bilgilendirileceksiniz.
            </p>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-3 text-left mb-4">
                <div class="modern-card p-3">
                    <small class="text-gray-500">Tahmini Teslimat</small>
                    <div class="font-semibold text-gray-900">Yarın, 10:00 - 13:00</div>
                </div>
                <div class="modern-card p-3">
                    <small class="text-gray-500">Ödeme Yöntemi</small>
                    <div class="font-semibold text-gray-900">Kredi Kartı</div>
                </div>
                <div class="modern-card p-3">
                    <small class="text-gray-500">Toplam Tutar</small>
                    <div class="font-semibold text-gray-900">463.90 TL</div>
                </div>
            </div>

            <div class="flex flex-col md:flex-row gap-2 justify-center">
                <a href="/Product/Index/" class="btn inline-flex items-center gap-x-2 bg-green-600 text-white border-green-600 hover:bg-green-700 hover:border-green-700">
                    Alışverişe Devam Et
                </a>
                <a href="/Order/Cart/" class="btn inline-flex items-center gap-x-2 bg-transparent text-gray-700 border-gray-300 hover:bg-gray-700 hover:text-white hover:border-gray-700">
                    Sepeti Görüntüle
                </a>
            </div>
        </div>
    </section>
</main>
