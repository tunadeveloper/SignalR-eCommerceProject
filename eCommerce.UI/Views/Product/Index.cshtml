@{
    ViewData["Title"] = "Ürünler ve Kategoriler";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<main>
    <section class="page-hero">
        <div class="container">
            <h1>Tüm Ürünler ve Kategoriler</h1>
            <p>Kategorilere göre filtrelenebilen, modern görünüme sahip statik ürün listesi.</p>
        </div>
    </section>

    <section class="container mb-10">
        <div class="modern-card p-4 p-lg-5 mb-4">
            <h2 class="section-title">Kategoriler</h2>
            <div class="flex flex-wrap gap-2">
                <a href="#!" class="category-chip">Meyve & Sebze</a>
                <a href="#!" class="category-chip">Atıştırmalık</a>
                <a href="#!" class="category-chip">İçecek</a>
                <a href="#!" class="category-chip">Temel Gida</a>
                <a href="#!" class="category-chip">Süt ve Kahvaltılık</a>
                <a href="#!" class="category-chip">Temizlik</a>
            </div>
        </div>

        <div class="grid gap-4 grid-cols-1 md:grid-cols-2 xl:grid-cols-4">
            <div class="modern-card p-4 product-tile">
                <img src="https://placehold.co/600x420/f3f4f6/6b7280?text=Organik+Elma" alt="Organik Elma">
                <div class="mt-3">
                    <span class="product-meta">Meyve & Sebze</span>
                    <h3 class="text-base font-semibold mt-1">Organik Elma (1 Kg)</h3>
                    <div class="mt-2">
                        <span class="price-new">89.90 TL</span>
                        <span class="price-old">109.90 TL</span>
                    </div>
                    <button class="btn inline-flex items-center gap-x-1 bg-green-600 text-white border-green-600 hover:bg-green-700 hover:border-green-700 mt-3">Sepete Ekle</button>
                </div>
            </div>

            <div class="modern-card p-4 product-tile">
                <img src="https://placehold.co/600x420/f3f4f6/6b7280?text=Fit+Granola" alt="Fit Granola">
                <div class="mt-3">
                    <span class="product-meta">Atıştırmalık</span>
                    <h3 class="text-base font-semibold mt-1">Fit Granola Bar (6 Adet)</h3>
                    <div class="mt-2">
                        <span class="price-new">124.50 TL</span>
                        <span class="price-old">139.90 TL</span>
                    </div>
                    <button class="btn inline-flex items-center gap-x-1 bg-green-600 text-white border-green-600 hover:bg-green-700 hover:border-green-700 mt-3">Sepete Ekle</button>
                </div>
            </div>

            <div class="modern-card p-4 product-tile">
                <img src="https://placehold.co/600x420/f3f4f6/6b7280?text=Cold+Brew" alt="Cold Brew">
                <div class="mt-3">
                    <span class="product-meta">İçecek</span>
                    <h3 class="text-base font-semibold mt-1">Cold Brew Kahve (250 ml)</h3>
                    <div class="mt-2">
                        <span class="price-new">54.90 TL</span>
                        <span class="price-old">64.90 TL</span>
                    </div>
                    <button class="btn inline-flex items-center gap-x-1 bg-green-600 text-white border-green-600 hover:bg-green-700 hover:border-green-700 mt-3">Sepete Ekle</button>
                </div>
            </div>

            <div class="modern-card p-4 product-tile">
                <img src="https://placehold.co/600x420/f3f4f6/6b7280?text=Dogal+Bal" alt="Doğal Bal">
                <div class="mt-3">
                    <span class="product-meta">Temel Gida</span>
                    <h3 class="text-base font-semibold mt-1">Doğal Çiçek Balı (850 gr)</h3>
                    <div class="mt-2">
                        <span class="price-new">219.00 TL</span>
                        <span class="price-old">249.00 TL</span>
                    </div>
                    <button class="btn inline-flex items-center gap-x-1 bg-green-600 text-white border-green-600 hover:bg-green-700 hover:border-green-700 mt-3">Sepete Ekle</button>
                </div>
            </div>
        </div>
    </section>
</main>
