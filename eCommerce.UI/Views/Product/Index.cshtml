@{
    ViewData["Title"] = "Ürünler ve Kategoriler";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<main>
    <section class="page-hero">
        <div class="container">
            <h1>Tüm Ürünler ve Kategoriler</h1>
            <p>Kategorilere göre filtrelenebilen, modern görünüme sahip statik ürün listesi.</p>
        </div>
    </section>

    <section class="container mb-10">
        @await Component.InvokeAsync("_CategoryListComponentPartial")
        @await Component.InvokeAsync("_ProductListComponentPartial")
    </section>
</main>
