@using eCommerce.UI.DTOs.ProductDTOs
@model List<ResultProductDTO>

<div class="grid gap-4 grid-cols-1 md:grid-cols-2 xl:grid-cols-4">

    @foreach(var item in Model)
    {
        <div class="modern-card p-4 product-tile">
            <img src="@(item.ProductImage[0])" alt="@item.ProductName">
            <div class="mt-3">
                <span class="product-meta">@item.CategoryName</span>
                <h3 class="text-base font-semibold mt-1">@item.ProductName</h3>
                <div class="mt-2">
                    <span class="price-new">@item.ProductNewPrice TL</span>
                    <span class="price-old">@item.ProductOldPrice TL</span>
                </div>
                <button class="btn inline-flex items-center gap-x-1 bg-green-600 text-white border-green-600 hover:bg-green-700 hover:border-green-700 mt-3">Sepete Ekle</button>
            </div>
        </div>
    }
</div>